# Environment Configuration - Production
# NEVER commit this file to git
# Copy from .env.example and fill in actual values

# ==========================================
# Database Configuration
# ==========================================

# SQLite for development (local only)
# SQLITE_URL=sqlite:///./test.db

# PostgreSQL for production (RDS)
# Format: postgresql://username:password@host:port/database
POSTGRES_URL="postgresql://postgres:YOUR_PASSWORD@your-rds-endpoint:5432/local_services"

# ==========================================
# JWT & Security
# ==========================================

# Generate with: openssl rand -hex 32
SECRET_KEY="your-secret-key-change-this-in-production"

# Algorithm for JWT
ALGORITHM="HS256"

# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES="30"

# ==========================================
# Application Settings
# ==========================================

# Environment: development, staging, production
ENVIRONMENT="production"

# Debug mode (NEVER True in production)
DEBUG="False"

# API Host
API_HOST="0.0.0.0"
API_PORT="8000"

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# ==========================================
# AWS Configuration
# ==========================================

# AWS region
AWS_REGION="us-east-1"

# S3 bucket for reports
S3_BUCKET="local-services-reports"

# AWS credentials (if not using IAM role)
# AWS_ACCESS_KEY_ID="your-key-id"
# AWS_SECRET_ACCESS_KEY="your-secret-key"

# ==========================================
# Redis Configuration (Phase 3+)
# ==========================================

# Redis URL
REDIS_URL="redis://127.0.0.1:6379/0"

# Redis password (if required)
# REDIS_PASSWORD="your-password"

# ==========================================
# Celery Configuration (Phase 3+)
# ==========================================

# Celery broker URL (use Redis)
CELERY_BROKER_URL="redis://127.0.0.1:6379/0"

# Celery result backend
CELERY_RESULT_BACKEND="redis://127.0.0.1:6379/0"

# ==========================================
# MongoDB Configuration (Phase 4+)
# ==========================================

# MongoDB connection URL
MONGODB_URL="mongodb://localhost:27017"

# MongoDB database name
MONGODB_DB="local_services"

# MongoDB username (if auth required)
# MONGODB_USER="username"

# MongoDB password (if auth required)
# MONGODB_PASSWORD="password"

# ==========================================
# API Settings
# ==========================================

# API title
API_TITLE="Local Services API"

# API version
API_VERSION="1.0.0"

# API description
API_DESCRIPTION="A crowdsourced solution for discovering local services"

# ==========================================
# Email Configuration (Future)
# ==========================================

# SMTP server
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# From email address
MAIL_FROM="noreply@local-services.com"

# ==========================================
# CORS Settings
# ==========================================

# Allowed origins (comma-separated)
CORS_ORIGINS="https://example.com,https://www.example.com"

# ==========================================
# Sentry Configuration (Error Tracking - Future)
# ==========================================

# SENTRY_DSN="your-sentry-dsn-url"

# ==========================================
# Stripe Configuration (Payment - Future)
# ==========================================

# STRIPE_API_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
