# Production Environment Variables
# NEVER commit this file! Use AWS Secrets Manager or GitHub Secrets instead
# Used with: export $(cat .env.prod | xargs) in production

# Application
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Database (use RDS endpoint)
POSTGRES_HOST=local-services-postgres.cqpiyq0usa9s.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=local_services
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${DB_PASSWORD_FROM_SECRETS_MANAGER}
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}

# JWT Security (generate with: openssl rand -hex 32)
SECRET_KEY=${GENERATED_SECRET_KEY}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS (restrict to your domain)
CORS_ORIGINS=["https://yourdomain.com", "https://api.yourdomain.com"]

# Redis
REDIS_URL=redis://redis-endpoint:6379/0

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_KEY_FROM_SECRETS}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_FROM_SECRETS}
S3_BUCKET=local-services-prod-reports
